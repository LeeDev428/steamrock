# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change-this-to-a-long-random-secret

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_BASE_FOLDER=StreamRock

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use an App Password (not your normal Gmail password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
# Email address that receives new booking notifications
ADMIN_EMAIL=your_admin@gmail.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
